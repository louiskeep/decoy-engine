# Standard Sphinx Makefile.
# Generated by sphinx-quickstart, with a few decoy-specific helpers added.
# Build:    make html
# Clean:    make clean
# Strict:   make html-strict      (mirrors CI's -W behavior)

SPHINXOPTS    ?=
SPHINXBUILD   ?= sphinx-build
SOURCEDIR     = .
BUILDDIR      = _build

.PHONY: help
help:
	@$(SPHINXBUILD) -M help "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)

.PHONY: html
html:
	@$(SPHINXBUILD) -b html "$(SOURCEDIR)" "$(BUILDDIR)/html" $(SPHINXOPTS) $(O)

# Strict mode: warnings-as-errors, keep going past the first error so a
# contributor sees every problem in one pass. Mirrors what CI does in
# .github/workflows/docs.yml — a green local `make html-strict` is the
# contract for a green Pages deploy.
.PHONY: html-strict
html-strict:
	@$(SPHINXBUILD) -b html -W --keep-going "$(SOURCEDIR)" "$(BUILDDIR)/html" $(SPHINXOPTS) $(O)

.PHONY: clean
clean:
	rm -rf "$(BUILDDIR)"

# Fall-through: forwards `make linkcheck`, `make doctest`, etc. to Sphinx.
.PHONY: Makefile
%: Makefile
	@$(SPHINXBUILD) -M $@ "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)
